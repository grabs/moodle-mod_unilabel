{{!
    @template unilabeltype_grid/grid_modal

    Context variables required for this template:
    * title A cleaned string (use clean_text()) to display.
    * body HTML content for the boday

    Example context (json):
    {
        "title": "Example title",
        "body": "&nbsp;"
    }
}}

{{< core/modal }}
    {{$footer}}
        <button type="button" class="btn btn-primary" data-action="hide" aria-label="{{#str}} closebuttontitle {{/str}}">{{#str}} closebuttontitle {{/str}}</button>
    {{/footer}}
{{/ core/modal }}
