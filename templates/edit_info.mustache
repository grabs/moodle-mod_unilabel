{{!
    @template mod_unilabel/edit_info
    Shows an alert box with edit informations to a unilabeltype.

    Example context (json):
    {
        "pluginname": "Collapsed text",
        "edit_info": "<div>Edit info</div>"
    }
}}

<div class="d-none d-xl-flex">
    <div class="alert alert-info d-flex">
        <i class="fa fa-info-circle fa-2x fa-fw text-info me-1"></i>
        <div><strong>{{pluginname}}</strong><br>{{{edit_info}}}</div>
    </div>
</div>
<div class="d-block d-xl-none">
    <button class="btn btn-link btn-sm mb-1" data-bs-toggle="collapse" data-bs-target="#unilabletype-info-{{uniqid}}">
        <i class="fa fa-info-circle fa-lg fa-fw text-info me-1"></i>
    </button>
    <div id="unilabletype-info-{{uniqid}}" class="collapse alert alert-info mt-1">
        <div><strong>{{pluginname}}</strong><br>{{{edit_info}}}</div>
    </div>
</div>
